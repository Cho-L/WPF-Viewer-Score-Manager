<Window x:Class="WpfDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfDemo"
        mc:Ignorable="d"
        Title="UPI 시청자 점수표"
        Height="780"
        Width="1500"
        MinHeight="640"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:ScoreToBrushConverter x:Key="ScoreToBrushConverter" />
    </Window.Resources>

    <Grid Background="#FFF4F6FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="20,20,20,12"
                Padding="20"
                Background="White"
                BorderBrush="#FFD8E1F0"
                BorderThickness="1"
                CornerRadius="18"
                Panel.ZIndex="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>

                <Border Width="120"
                        Height="120"
                        CornerRadius="16"
                        Background="#FFF7F9FD"
                        BorderBrush="#FFD8E1F0"
                        BorderThickness="1">
                    <Grid>
                        <Image Source="{Binding UpiImageSource}" Stretch="Uniform" Margin="8" />
                        <TextBlock Text="UPI 이미지"
                                   Foreground="#FF7B8794"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding UpiImageHintVisibility}" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,20,0" VerticalAlignment="Center">
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#FF1C2A39"
                               Text="UPI 시청자 점수표" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#FF526274"
                               Text="시청자별 점수 입력, 열 추가, 자동 합계 계산, 자동 저장과 자동 복원을 한 화면에서 관리합니다." />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#FF0B5CAD"
                               FontWeight="SemiBold"
                               Text="뿌요 이미지는 헤더 옆 장식으로 표시됩니다." />
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <Button Height="38" Margin="0,0,0,10" Content="UPI 이미지 바꾸기" Click="LoadUpiImage_Click" />
                    <Button Height="38" Content="뿌요 이미지 바꾸기" Click="LoadPpuyoImage_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="20,0,20,12"
                Padding="16"
                Background="White"
                BorderBrush="#FFD8E1F0"
                BorderThickness="1"
                CornerRadius="12"
                Panel.ZIndex="2">
            <WrapPanel>
                <Button MinWidth="110" Margin="0,0,10,10" Content="행 추가" Click="AddRow_Click" />
                <Button MinWidth="110" Margin="0,0,10,10" Content="위에 삽입" Click="InsertAbove_Click" />
                <Button MinWidth="110" Margin="0,0,10,10" Content="아래에 삽입" Click="InsertBelow_Click" />
                <Button MinWidth="110" Margin="0,0,10,10" Content="행 삭제" Click="DeleteRow_Click" />
                <Button MinWidth="110" Margin="0,0,10,10" Content="열 추가" Click="AddColumn_Click" />
                <Button MinWidth="110" Margin="0,0,10,10" Content="열 이름 변경" Click="RenameColumn_Click" />
                <Button MinWidth="110" Margin="0,0,10,10" Content="선택 열 삭제" Click="DeleteColumn_Click" />
                <Button MinWidth="110" Margin="0,0,10,10" Content="샘플 불러오기" Click="LoadSample_Click" />
                <Button MinWidth="110" Margin="0,0,10,10" Content="파일 저장" Click="Save_Click" />
                <Button MinWidth="110" Margin="0,0,10,10" Content="파일 불러오기" Click="Load_Click" />
            </WrapPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="20,0,20,12"
                Padding="16"
                Background="White"
                BorderBrush="#FFD8E1F0"
                BorderThickness="1"
                CornerRadius="12"
                Panel.ZIndex="2">
            <DataGrid x:Name="TableGrid"
                      AutoGenerateColumns="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      FrozenColumnCount="1"
                      HeadersVisibility="All"
                      GridLinesVisibility="All"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      SelectionMode="Extended"
                      SelectionUnit="CellOrRowHeader"
                      AutoGeneratingColumn="TableGrid_AutoGeneratingColumn"
                      AutoGeneratedColumns="TableGrid_AutoGeneratedColumns"
                      PreparingCellForEdit="TableGrid_PreparingCellForEdit"
                      CellEditEnding="TableGrid_CellEditEnding" />
        </Border>

        <Border Grid.Row="3"
                Margin="20,0,20,20"
                Padding="14,10"
                Background="White"
                BorderBrush="#FFD8E1F0"
                BorderThickness="1"
                CornerRadius="12"
                Panel.ZIndex="2">
            <DockPanel LastChildFill="True">
                <TextBlock FontWeight="SemiBold" Text="상태: " />
                <TextBlock x:Name="StatusTextBlock"
                           Margin="0,0,18,0"
                           Foreground="#FF526274"
                           Text="준비 완료" />
                <TextBlock FontWeight="SemiBold" Text="전체 합계: " />
                <TextBlock x:Name="OverallScoreTextBlock"
                           Foreground="#FF0B5CAD"
                           Text="0" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
